generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TestResult {
  id           String   @id @default(cuid())
  userId       String?
  testType     String
  score        Float?
  wpm          Float?
  accuracy     Float?
  reactionTime Float?
  points       Int?
  timestamp    DateTime @default(now())

  @@index([userId])
  @@index([testType])
  @@index([timestamp])
  @@index([userId, testType])
}

model UserProfile {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  username    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([firebaseUid])
}
